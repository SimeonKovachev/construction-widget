{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish src/ConstructionWidget.Api/ConstructionWidget.Api.csproj -c Release -o /app/out"
  },
  "deploy": {
    "startCommand": "dotnet /app/out/ConstructionWidget.Api.dll",
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
